#!/usr/bin/env bash
#
# +----------------------------------------------------------------------------+
# | ./fancy-motd/config.sh                                                     |
# +----------------------------------------------------------------------------+
# |       Usage: ---                                                           |
# | Description: Configuration file for Fancy MOTD                             |
# |    Requires: Fancy MOTD                                                    |
# |       Notes: ---                                                           |
# |      Author: Waldemar Schroeer                                             |
# |     Company: Rechenzentrum Amper                                           |
# |     Version: 1.1                                                           |
# |     Created: 2021-03-31                                                    |
